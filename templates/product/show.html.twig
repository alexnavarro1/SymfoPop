{# Afegeixo l'arrel de plantilles #}
{% extends 'base.html.twig' %}

{% block title %}{{ product.title }} - SymfoPop{% endblock %}

{% block body %}
    <div class="mb-4">
        {# El meu simple botó pel retorn fàcil #}
        <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="bi bi-arrow-left"></i> Tornar al llistat</a>
    </div>

    {# La targeta amplida general a nivell gran del mode detall, a 1 sola vista #}
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-5">
        <div class="row g-0">
            <div class="col-md-6 border-end position-relative bg-light">
                {# Dibuixo l'enllaç original per fer la imatge #}
                {% if product.image %}
                    <img src="{{ product.image }}" class="img-fluid w-100 h-100" style="object-fit: contain; min-height: 400px; max-height: 600px;" alt="{{ product.title }}">
                {% else %}
                    <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted" style="min-height: 400px;">
                        <i class="bi bi-image" style="font-size: 6rem; opacity: 0.1;"></i>
                    </div>
                {% endif %}
            </div>
            <div class="col-md-6">
                <div class="card-body p-4 p-lg-5 d-flex flex-column h-100">
                    {# Demostro quin títol concret utilitza sense truncar! #}
                    <h1 class="card-title fw-bold text-dark mb-4">{{ product.title }}</h1>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded-3 shadow-sm">
                        <div class="display-6 fw-bold text-success">{{ product.price|number_format(2, ',', '.') }} €</div>
                    </div>

                    <div class="d-flex gap-4 mb-4 text-muted small border-bottom pb-4">
                        <div><i class="bi bi-calendar3 text-primary"></i> <strong>Data:</strong> {{ product.createdAt|date('d/m/Y H:i') }}</div>
                        <div><i class="bi bi-person-circle text-primary"></i> <strong>Venedor:</strong> {{ product.owner.name }}</div>
                    </div>

                    <h5 class="fw-bold mb-3">Descripció del Producte</h5>
                    {# Aquí em salto manualment de l'HTML l'espaiat 'pre-line' visualizant el bloc de paràgraf i els enters ocults per visualització perfecte com ha posat de base. #}
                    <div class="card-text mb-4 fs-6 lh-lg text-secondary" style="white-space: pre-line;">
                        {{ product.description }}
                    </div>

                    <div class="mt-auto">
                        {# La segona comprovació estricta que Twig realitza: només apareix si estic loguejat (!== null) i l'usuari sóc JO i no un extrany. #}
                        {% if app.user and app.user == product.owner %}
                            <div class="d-flex justify-content-end gap-2 p-3 bg-light rounded-3 mt-4">
                                <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-warning fw-bold px-4"><i class="bi bi-pencil"></i> Editar</a>
                                {# També afegeixo l'acció destructora dins directament en la visió específica del dit producte per si de repent em cansa #}
                                <form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Estàs completament segur que vols esborrar aquest producte? Aquesta acció no es pot desfer.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                    <button class="btn btn-danger fw-bold px-4"><i class="bi bi-trash"></i> Esborrar</button>
                                </form>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
