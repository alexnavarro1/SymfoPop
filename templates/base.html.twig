{# Aquesta és la vista mare per a tota la pàgina web d'aparença general que recobreix tot. #}
<!DOCTYPE html>
<html lang="ca">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}SymfoPop{% endblock %}</title>
        {# Afegeixo el disseny sencer de Bootstrap 5 per CDN per garantir que funcioni fàcilment i estilitzat minimalista. #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        {# Introdueixo paquet llarg dels Bootstrap Icons perquè quedi tot decorat visualment més maco. #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        {% block stylesheets %}
        {% endblock %}
        {% block javascripts %}
        {% endblock %}
    </head>
    <body class="bg-light">
        {# Construeixo aquí la meva barra de menú "navbar" principal, amb el logo. #}
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">
                    <i class="bi bi-shop"></i> SymfoPop
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_product_index') }}">Productes</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        {# Diferencio directament el menú si jo ('app.user') he iniciat o no sessió previament. #}
                        {% if app.user %}
                            <li class="nav-item me-3">
                                <span class="nav-link text-white-50"><i class="bi bi-person-circle"></i> Hola, {{ app.user.name }}</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_my_products') }}">Els meus productes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_product_new') }}">Nou producte</a>
                            </li>
                            <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">Tancar sessió</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">Iniciar Sessió</a>
                            </li>
                            <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                                <a class="btn btn-light text-primary fw-bold" href="{{ path('app_register') }}">Registrar-se</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {# La capsa d'on penja tot el contingut lliure intern de cada pàgina de Symfony. #}
        <div class="container pb-5">
            {# Faig un bucle sencer a l'escut global del "flashbag" session per mostrar qualsevol alerteta global bonica d'èxit/error abans d'una caixa d'alert alert dismissable #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# Incorporem les vistes netes on calguin un cop recobert de headers/scripts generalment cridats mitjançant twig. #}
            {% block body %}{% endblock %}
        </div>

        {# Llibreries de comportament visual en JS pel Bootstrap... #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
